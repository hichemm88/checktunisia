{
  "expo": {
    "name": "Qayed",
    "slug": "qayed-mobile",
    "scheme": "qayed",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F5F1"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "tn.qayed.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Qayed utilise la caméra pour scanner la bande MRZ des passeports lors de l'enregistrement des voyageurs."
      }
    },
    "android": {
      "package": "tn.qayed.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6F5F1"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Qayed accède à vos photos pour importer une photo de passeport.",
          "cameraPermission": "Qayed utilise la caméra pour photographier le passeport lors de l'enregistrement."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5346A8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "hichou88",
    "extra": {
      "apiUrl": "https://checktunisia-backend-production.up.railway.app/api/v1",
      "eas": {
        "projectId": "41db4a28-deae-4786-842f-081047dfa3fd"
      }
    }
  }
}
